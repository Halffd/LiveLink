{
  "path": "streamlink",
  "options": {
    "player": "mpv",
    "player-args": "--input-ipc-server=/tmp/livelink_mpv_ipc",
    "default-stream": "best",
    "stream-timeout": 60,
    "player-no-close": true,
    "twitch-disable-hosting": true,
    "twitch-disable-ads": true,
    "twitch-low-latency": true,
    "twitch-low-latency-mode": "auto",
    "twitch-player-vod-chat": false,
    "twitch-game-category-notify": true,
    "retry-max": 5,
    "retry-streams": 5,
    "ringbuffer-size": "128M",
    "player-continuous-http": true,
    "stream-segment-attempts": 5,
    "stream-segment-threads": 3,
    "fs-buffer": "large",
    "http-disable-redirect": false,
    "http-ssl-verify": true,
    "http-headers": {},
    "http-cookies": {},
    "http-proxy": null,
    "hls-live-edge": 4,
    "hls-segment-queue-threshold": 3,
    "hls-segment-key": null,
    "hls-session-key": false,
    "hls-start-offset": null,
    "dash-live-edge": 3,
    "dash-segment-queue-threshold": 2,
    "dvr-window": 0,
    "default-title": "{title} - {author} - {category}",
    "player-process-name": null,
    "player-fifo": false,
    "player-rc": false,
    "player-passthrough": {},
    "subtitles": false,
    "subtitles-language": "en",
    "subtitles-default": false,
    "locale": "en_US.UTF-8",
    "global-cache": true,
    "global-player": false,
    "global-http-disable": false,
    "stream-type": "auto",
    "transport-dump": null,
    "transport-timing": false
  },
  "http_header": {},
  "mpv": {
    "border": false,
    "ontop": true,
    "force-window": false,
    "cursor": false
  }
}