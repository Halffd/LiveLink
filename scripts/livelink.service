[Unit]
Description=LiveLink Server
After=network-online.target

[Service]
WorkingDirectory=/home/all/repos/LiveLink
ExecStart=/usr/bin/bash /home/all/scripts/livelink.sh
Restart=always
RestartSec=5
EnvironmentFile=%h/.config/livelink.env
# Logging — send everything to the journal instead of invalid STDOUT targets
StandardOutput=journal
StandardError=journal
# Optional: make sure PATH and env are sane
Environment=NODE_ENV=production

[Install]
WantedBy=default.target
